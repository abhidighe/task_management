{
  "name": "task-management-api",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js + Express + TypeScript API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e src/env/.env.development -- nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prod": "dotenv -e src/env/.env.production -- node dist/index.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.0",
    "dotenv-cli": "^5.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
